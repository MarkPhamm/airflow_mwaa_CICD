{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketVersioning"
      ],
      "Resource": [
        "arn:aws:s3:::airflow-my-mwaa-bucket",
        "arn:aws:s3:::airflow-my-mwaa-bucket/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "airflow:UpdateEnvironment",
        "airflow:GetEnvironment"
      ],
      "Resource": "*"
    }
  ]
}